{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "agrosinergia",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path');const dir=process.cwd();http.createServer((req,res)=>{let f=req.url==='/'?'/agrosinergia.html':req.url;let fp=path.join(dir,f);fs.readFile(fp,(err,data)=>{if(err){res.writeHead(404);res.end('Not found');return}let ct='text/html';if(f.endsWith('.js'))ct='text/javascript';if(f.endsWith('.css'))ct='text/css';if(f.endsWith('.json'))ct='application/json';res.writeHead(200,{'Content-Type':ct+'; charset=utf-8'});res.end(data)})}).listen(3000,()=>console.log('Server running on http://localhost:3000'))"],
      "port": 3000
    }
  ]
}
